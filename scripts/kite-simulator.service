[Unit]
Description=Zerodha Kite Ticker Simulator (WebSocket)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/kite-simulator/simulator
Environment=PYTHONUNBUFFERED=1

# Remove --force-open on production (respects real IST market hours)
# Add --force-open for 24/7 tick testing
ExecStart=/home/ubuntu/kite-simulator/venv/bin/python kite_simulator.py \
          --host 0.0.0.0 \
          --port 8765 \
          --interval 1.0 \
          --log-level INFO

Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=kite-simulator

[Install]
WantedBy=multi-user.target
