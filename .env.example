# Copy this to .env and fill in your values.
# .env is git-ignored — never commit it.

# ── Simulator server ────────────────────────────────────────────────────────
# Shown in the connect_url returned by POST /keys
SIM_HOST=YOUR_EC2_PUBLIC_IP
SIM_PORT=8765

# ── Client credentials (set after running POST /keys) ──────────────────────
# Used by ticker_sim.py to authenticate against the simulator
KITE_SIM_URL=ws://YOUR_EC2_PUBLIC_IP:8765
KITE_SIM_API_KEY=sim_replace_me
KITE_SIM_ACCESS_TOKEN=sat_replace_me

# ── MySQL (unchanged from original project) ────────────────────────────────
MYSQL_URL=mysql+pymysql://user:password@host:3306/alumnx_quant

# ── Real Kite (only needed if using ticker.py instead of ticker_sim.py) ────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=your_access_token_here
